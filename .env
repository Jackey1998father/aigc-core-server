# ===== 基本信息 =====
PROJECT_NAME=AIGC Core Server
VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=true

# ===== 服务器配置 =====
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ===== CORS 配置（本地开发默认全部放开）=====
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# ===== 安全配置 =====
# 本地开发不启用接口鉴权；生产环境请设置为强随机字符串
API_SECRET_TOKEN=
SECRET_KEY=local-dev-secret-key-change-me

# ===== 日志配置 =====
LOG_LEVEL=debug
LOG_FILE=

# ===== 限流配置 =====
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ENABLED=false

# ===== 上游模型服务 =====
SILICON_FLOW_URL=https://api.siliconflow.cn/v1/chat/completions
DEFAULT_MODEL=Pro/zai-org/GLM-5.1
SILICON_FLOW_API_KEY=
